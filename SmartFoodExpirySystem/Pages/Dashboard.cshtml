@page
@model SmartFoodExpirySystem.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "/Pages/Shared/_Layout.cshtml";
    var username = HttpContext.Session.GetString("Username");
}
@if (Model.ExpiringTomorrow.Any())
{
    <div id="expiryModalOverlay" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-icon">⏰</div>
            <h5>Heads up, @username!</h5>
            <p style="color:#666;font-size:0.9rem;">These items expire <strong>tomorrow</strong>:</p>
            <ul class="modal-list">
                @foreach (var item in Model.ExpiringTomorrow)
                {
                    <li>@item.ItemName <span class="text-muted">— @item.Quantity</span></li>
                }
            </ul>
            <button class="btn btn-success w-100"
                    onclick="document.getElementById('expiryModalOverlay').style.display='none'">
                Got it! ✓
            </button>
        </div>
    </div>
}

<!-- Stat Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="stat-card bg-green">
            <span class="stat-icon">📦</span>
            <div class="number">@Model.TotalItems</div>
            <div class="label">Total Items</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-success">
            <span class="stat-icon">✅</span>
            <div class="number">@Model.AvailableItems</div>
            <div class="label">Available</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-warning">
            <span class="stat-icon">⚠️</span>
            <div class="number">@Model.ExpiringItems</div>
            <div class="label">Expiring Soon</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card bg-danger">
            <span class="stat-icon">❌</span>
            <div class="number">@Model.ExpiredItems</div>
            <div class="label">Expired</div>
        </div>
    </div>
</div>

<!-- Visual Chart Row -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-title">📊 Item Status Overview</div>
            @{
                int total = Model.TotalItems > 0 ? Model.TotalItems : 1;
                int availPct = (int)((double)Model.AvailableItems / total * 100);
                int expiringPct = (int)((double)Model.ExpiringItems / total * 100);
                int expiredPct = (int)((double)Model.ExpiredItems / total * 100);
            }
            <div style="margin-bottom:14px;">
                <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
                    <span style="font-size:0.84rem;font-weight:600;color:#166534;">✅ Available</span>
                    <span style="font-size:0.84rem;font-weight:700;">@Model.AvailableItems (@availPct%)</span>
                </div>
                <div style="background:#e9ecef;border-radius:30px;height:10px;overflow:hidden;">
                    <div style="width:@(availPct)%;height:100%;background:linear-gradient(90deg,#28a745,#5fd383);border-radius:30px;"></div>
                </div>
            </div>
            <div style="margin-bottom:14px;">
                <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
                    <span style="font-size:0.84rem;font-weight:600;color:#92660a;">⚠️ Expiring Soon</span>
                    <span style="font-size:0.84rem;font-weight:700;">@Model.ExpiringItems (@expiringPct%)</span>
                </div>
                <div style="background:#e9ecef;border-radius:30px;height:10px;overflow:hidden;">
                    <div style="width:@(expiringPct)%;height:100%;background:linear-gradient(90deg,#ffc107,#ffd166);border-radius:30px;"></div>
                </div>
            </div>
            <div>
                <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
                    <span style="font-size:0.84rem;font-weight:600;color:#991b1b;">❌ Expired</span>
                    <span style="font-size:0.84rem;font-weight:700;">@Model.ExpiredItems (@expiredPct%)</span>
                </div>
                <div style="background:#e9ecef;border-radius:30px;height:10px;overflow:hidden;">
                    <div style="width:@(expiredPct)%;height:100%;background:linear-gradient(90deg,#dc3545,#ff7b8a);border-radius:30px;"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-title">🍽️ Quick Actions</div>
            <div style="display:flex;flex-direction:column;gap:10px;">
                <a href="/AddFoodItem" class="btn btn-success">➕ Add New Food Item</a>
                <a href="/Inventory" class="btn btn-warning">📦 View Inventory</a>
                <a href="/ShoppingPlanner" class="btn"
                   style="background:linear-gradient(135deg,#6f42c1,#b08df7);color:white;">
                    🛒 Shopping Planner
                </a>
                <a href="/ExpiryAlerts" class="btn btn-danger">🔔 View Expiry Alerts</a>
            </div>
        </div>
    </div>
</div>

<!-- Bottom Row -->
<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-title">⚠️ Expiring Within 3 Days</div>
            @if (Model.ExpiringList.Any())
            {
                <table>
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Qty</th>
                            <th>Days Left</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.ExpiringList)
                        {
                            int days = (item.ExpiryDate.Date - DateTime.Today).Days;
                            <tr>
                                <td><strong>@item.ItemName</strong></td>
                                <td class="text-muted">@item.Quantity</td>
                                <td>
                                    <span class="badge @(days == 0 ? "badge-danger" : "badge-warning")">
                                        @(days == 0 ? "Today!" : days + "d left")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">🎉</div>
                    <p>No items expiring soon!</p>
                </div>
            }
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-title">🛒 Shopping List</div>
            @if (Model.ShoppingList.Any())
            {
                <table>
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.ShoppingList)
                        {
                            <tr>
                                <td><strong>@s.ItemName</strong></td>
                                <td>
                                    <span class="badge @(s.Status == "Purchased" ? "badge-success" : "badge-secondary")">
                                        @s.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">🛒</div>
                    <p>Shopping list is empty.</p>
                </div>
            }
        </div>
    </div>
</div>