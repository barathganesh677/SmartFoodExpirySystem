@page
@model SmartFoodExpirySystem.Pages.RegisterModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Register - Smart Food</title>
    <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            @@keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(24px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @@keyframes floatBlob {
                0%, 100% {
                    transform: translate(0, 0) scale(1);
                }

                50% {
                    transform: translate(-20px, 30px) scale(1.08);
                }
            }

            @@keyframes popIn {
                0% {
                    opacity: 0;
                    transform: scale(0.9);
                }

                100% {
                    opacity: 1;
                    transform: scale(1);
                }
            }

            body {
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Segoe UI', Tahoma, sans-serif;
                background: linear-gradient(135deg, #155e38 0%, #1a7a4a 50%, #2fa86b 100%);
                position: relative;
                overflow: hidden;
            }

            .blob {
                position: absolute;
                border-radius: 50%;
                background: rgba(255,255,255,0.08);
                animation: floatBlob 9s ease-in-out infinite;
            }

            .blob1 {
                width: 280px;
                height: 280px;
                top: -70px;
                right: -70px;
            }

            .blob2 {
                width: 200px;
                height: 200px;
                bottom: -50px;
                left: -50px;
                animation-delay: 2.5s;
            }

            .blob3 {
                width: 140px;
                height: 140px;
                top: 65%;
                left: 80%;
                animation-delay: 5s;
                background: rgba(255,209,102,0.12);
            }

            .auth-card {
                background: white;
                border-radius: 20px;
                padding: 40px 36px;
                width: 100%;
                max-width: 400px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.25);
                position: relative;
                z-index: 2;
                animation: fadeInUp 0.6s cubic-bezier(.23,1,.32,1);
            }

            .auth-logo {
                text-align: center;
                font-size: 2.6rem;
                margin-bottom: 4px;
                animation: popIn 0.5s ease-out 0.1s both;
            }

            .auth-title {
                text-align: center;
                font-size: 1.4rem;
                font-weight: 800;
                color: #1a3c2b;
                margin-bottom: 4px;
            }

            .auth-subtitle {
                text-align: center;
                font-size: 0.88rem;
                color: #888;
                margin-bottom: 24px;
            }

            .form-group {
                margin-bottom: 18px;
            }

            .form-label {
                display: block;
                font-size: 0.85rem;
                font-weight: 700;
                color: #444;
                margin-bottom: 6px;
            }

            .form-control {
                width: 100%;
                padding: 12px 14px;
                border: 1.5px solid #e2e8f0;
                border-radius: 10px;
                font-size: 0.95rem;
                transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
            }

                .form-control:focus {
                    outline: none;
                    border-color: #28a745;
                    box-shadow: 0 0 0 4px rgba(40,167,69,0.12);
                    transform: translateY(-1px);
                }

            .btn-submit {
                width: 100%;
                padding: 13px;
                border: none;
                border-radius: 10px;
                background: linear-gradient(135deg, #28a745, #1a7a4a);
                color: white;
                font-size: 1rem;
                font-weight: 700;
                cursor: pointer;
                margin-top: 6px;
                box-shadow: 0 6px 18px rgba(40,167,69,0.3);
                transition: transform 0.2s ease, box-shadow 0.2s ease;
            }

                .btn-submit:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 10px 24px rgba(40,167,69,0.4);
                }

                .btn-submit:active {
                    transform: scale(0.98);
                }

            .auth-footer {
                text-align: center;
                margin-top: 18px;
                font-size: 0.88rem;
                color: #666;
            }

                .auth-footer a {
                    color: #1a7a4a;
                    font-weight: 700;
                    text-decoration: none;
                    transition: color 0.2s ease;
                }

                    .auth-footer a:hover {
                        color: #28a745;
                        text-decoration: underline;
                    }

            .alert {
                padding: 12px 16px;
                border-radius: 10px;
                margin-bottom: 18px;
                font-size: 0.88rem;
                animation: popIn 0.35s ease-out;
                border-left: 4px solid #dc3545;
                background: #fdecee;
                color: #991b1b;
            }
    </style>
</head>
<body>
    <div class="blob blob1"></div>
    <div class="blob blob2"></div>
    <div class="blob blob3"></div>

    <div class="auth-card">
        <div class="auth-logo">🥦</div>
        <div class="auth-title">Create Account</div>
        <div class="auth-subtitle">Join Smart Food Expiry Tracker</div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert">⚠️ @Model.ErrorMessage</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Username</label>
                <input asp-for="Input.Username" class="form-control" placeholder="Enter your username" />
            </div>
            <div class="form-group">
                <label class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" />
            </div>
            <div class="form-group">
                <label class="form-label">Password</label>
                <input asp-for="Input.Password" type="password" class="form-control" placeholder="Create a password" />
            </div>
            <button type="submit" class="btn-submit">Register</button>
        </form>

        <div class="auth-footer">
            Already have an account? <a href="/Login">Login here</a>
        </div>
    </div>
</body>
</html>