@page
@model SmartFoodExpirySystem.Pages.RegisterModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Create Account — SmartFood</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
            :root {
                --primary: #16a34a;
                --primary-hover: #15803d;
                --bg: #f8fafc;
                --surface: #ffffff;
                --border: #e2e8f0;
                --text: #0f172a;
                --text-2: #334155;
                --text-3: #64748b;
                --text-4: #94a3b8;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            @@keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            body {
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Plus Jakarta Sans', sans-serif;
                background: linear-gradient(135deg, #f0fdf4, #f8fafc, #f0fdf4);
                color: var(--text);
                padding: 32px 16px;
            }

            .auth-card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 16px;
                padding: 40px;
                width: 100%;
                max-width: 440px;
                box-shadow: 0 20px 40px rgba(15,23,42,0.08);
                animation: fadeUp 0.5s ease-out;
            }

            .auth-logo {
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 30px;
            }

            .auth-logo-icon {
                width: 36px;
                height: 36px;
                background: linear-gradient(135deg, var(--primary), #22c55e);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1rem;
            }

            .auth-logo-name {
                font-size: 1rem;
                font-weight: 800;
                color: var(--text);
            }

            .auth-title {
                font-size: 1.4rem;
                font-weight: 800;
                color: var(--text);
                letter-spacing: -0.4px;
                margin-bottom: 4px;
            }

            .auth-sub {
                font-size: 0.84rem;
                color: var(--text-3);
                margin-bottom: 28px;
            }

            .form-group {
                margin-bottom: 16px;
            }

            .form-label {
                display: block;
                font-size: 0.82rem;
                font-weight: 600;
                color: var(--text-2);
                margin-bottom: 6px;
            }

            .form-control {
                width: 100%;
                padding: 11px 14px;
                background: var(--bg);
                border: 1.5px solid var(--border);
                border-radius: 10px;
                color: var(--text);
                font-size: 0.9rem;
                font-family: inherit;
                transition: all 0.18s ease;
            }

                .form-control:focus {
                    outline: none;
                    border-color: var(--primary);
                    background: white;
                    box-shadow: 0 0 0 3px rgba(22,163,74,0.1);
                }

                .form-control::placeholder {
                    color: var(--text-4);
                }

            .btn-submit {
                width: 100%;
                padding: 12px;
                background: var(--primary);
                border: none;
                border-radius: 10px;
                color: white;
                font-size: 0.9rem;
                font-weight: 700;
                cursor: pointer;
                font-family: inherit;
                transition: all 0.2s ease;
                box-shadow: 0 4px 12px rgba(22,163,74,0.3);
                margin-top: 6px;
            }

                .btn-submit:hover {
                    background: var(--primary-hover);
                    box-shadow: 0 6px 18px rgba(22,163,74,0.4);
                    transform: translateY(-1px);
                }

            .divider {
                height: 1px;
                background: var(--border);
                margin: 22px 0;
            }

            .auth-footer {
                text-align: center;
                font-size: 0.84rem;
                color: var(--text-3);
            }

                .auth-footer a {
                    color: var(--primary);
                    font-weight: 600;
                    text-decoration: none;
                }

                    .auth-footer a:hover {
                        text-decoration: underline;
                    }

            .alert {
                padding: 12px 14px;
                background: #fee2e2;
                border: 1px solid #fecaca;
                border-radius: 8px;
                color: #dc2626;
                font-size: 0.84rem;
                font-weight: 500;
                margin-bottom: 18px;
                display: flex;
                align-items: center;
                gap: 8px;
            }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="auth-logo">
            <div class="auth-logo-icon">🥦</div>
            <div class="auth-logo-name">SmartFood</div>
        </div>

        <div class="auth-title">Create your account</div>
        <div class="auth-sub">Start tracking your groceries for free</div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert">⚠️ @Model.ErrorMessage</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Full name</label>
                <input asp-for="Input.Username" class="form-control" placeholder="Barath Ganesh" />
            </div>
            <div class="form-group">
                <label class="form-label">Email address</label>
                <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" />
            </div>
            <div class="form-group">
                <label class="form-label">Password</label>
                <input asp-for="Input.Password" type="password" class="form-control" placeholder="Create a strong password" />
            </div>
            <button type="submit" class="btn-submit">Create account →</button>
        </form>

        <div class="divider"></div>
        <div class="auth-footer">
            Already have an account? <a href="/Login">Sign in</a>
        </div>
    </div>
</body>
</html>